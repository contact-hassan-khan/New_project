PORT=3000
NODE_ENV=development
UPLOAD_DIR=./backend/uploads
DATA_DIR=./backend/data
MAX_FILE_SIZE=10485760
ALLOWED_SYLLABUS_TYPES=.pdf,.doc,.docx
ALLOWED_RESUME_TYPES=.pdf,.doc,.docx

# Security
JWT_SECRET=cyberelite-secret-key-2024-change-in-production-min-32-chars
ADMIN_PASSWORD=cyberelite2024!SecurePass

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@cyberelite.com
CONTACT_EMAIL=contact@cyberelite.com
HR_EMAIL=careers@cyberelite.com

# Company Information
COMPANY_PHONE=+91-9890467034
COMPANY_EMAIL=info@cyberelite.com
